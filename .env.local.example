# Anon / Publishable key — safe to expose (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB6d3Vtb3Rxbm5teG5zcmZqYWx6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNzcxNTksImV4cCI6MjA5MDk1MzE1OX0.sENwC9JJR2q2Ig272LxBKirya3lEryOtEIkTJrqWuD4

# Service Role key — SERVER ONLY, never expose to the browser.
# Required for Sprint 2 CSV import (lib/supabase/admin.ts).
# Set this in Vercel now so it's ready when Sprint 2 ships.
# Found in: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production.
# Used by auth callback redirects. Include protocol, no trailing slash.
# Local:      http://localhost:3000
# Production: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
